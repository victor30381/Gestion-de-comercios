rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // 0. REGLAS PARA PERFILES DE USUARIO (Acceso público para el Catálogo)
    // ---------------------------------------------------------
    match /userProfiles/{userId} {
      // PERMITIR VISTA PÚBLICA DE PERFILES para que el catálogo cargue el logo/nombre
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // 1. REGLA DE PRIVACIDAD PARA TUS CLIENTES ('clients')
    // ---------------------------------------------------------
    match /clients/{documentId} {
      // Para LEER, EDITAR o BORRAR: 
      // Permitir solo si el campo 'userId' guardado coincide con el ID de quien entra.
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Para CREAR un nuevo cliente:
      // Permitir solo si el usuario guarda su propio ID en el campo 'userId'.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------
    // 2. REGLAS PARA RECETAS, INGREDIENTES Y ÓRDENES
    // ---------------------------------------------------------
    
    match /recipes/{document=**} { 
      // Permitir vista si está en catálogo PÚBLICO
      allow read: if (resource == null || resource.data.showInCatalog == true) || request.auth != null; 
      allow write: if request.auth != null; 
    }
    match /ingredients/{document=**} { 
      allow read, write: if request.auth != null; 
    }
    
    // Para las órdenes ('orders')
    match /orders/{document=**} { 
      // Permitir que el catálogo PÚBLICO cree pedidos.
      allow create: if true;
      allow read, update, delete: if request.auth != null; 
    }
  }
}
