rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check ownership
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Helper to check standard resource ownership
    function isResourceOwner() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Allow user to write to their own subcollections (if migration happens later)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Root collections - Enforce userId matching
    // Note: We explicitly allow negative stock by NOT adding a create/update condition on stock values.

    match /ingredients/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /production_logs/{docId} {
       allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /recipes/{docId} {
       allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /orders/{docId} {
       allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    match /clients/{docId} {
       allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
    
    // Notifications (if used)
     match /notifications/{docId} {
       allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
  }
}
